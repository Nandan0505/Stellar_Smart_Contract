
DEPLOYER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your Stellar public key (starts with G) — derived from the secret above
DEPLOYER_PUBLIC=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Network ───────────────────────────────────────────────────────────────────

# Target network: testnet | mainnet
STELLAR_NETWORK=testnet

# ── Contract ──────────────────────────────────────────────────────────────────

# Soroban contract ID — filled in automatically by deploy.sh after deployment
# Looks like: CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CONTRACT_ID=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_CONTRACT_ID=xxxxxxxxx
VITE_STELLAR_NETWORK=testnet

# A funded public key used for read-only (simulation) calls.
VITE_READ_SOURCE_KEY=